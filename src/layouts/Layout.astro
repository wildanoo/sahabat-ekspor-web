---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <link rel='icon' type='image/png' href='/assets/favicon.png' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Archivo:wght@400..900&family=Archivo:ital,wdth,wght@0,62..125,400..900&family=IBM+Plex+Mono:wght@400;500;600&family=Source+Sans+3:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
  </head>
  <body>
    <slot />

    <footer class='footer'>
      <div class='footer-inner'>
        <div class='footer-top'>
          <div>
            <img
              src='/assets/logo.png'
              alt='Sahabat Export'
              class='footer-logo'
            />
            <p class='footer-tag'>
              Selling Indonesian products to Malaysia &amp; Singapore through
              digital marketing and cross-border fulfillment.
            </p>
          </div>
          <nav class='footer-nav' aria-label='Footer'>
            <div class='footer-col'>
              <h4>Explore</h4>
              <a href='#about'>About</a>
              <a href='#markets'>Markets</a>
              <a href='#products'>Products</a>
              <a href='#operate'>How we work</a>
            </div>
            <div class='footer-col'>
              <h4>Connect</h4>
              <a href='#faq'>FAQ</a>
              <a href='#contact'>Partnership</a>
              <a href='mailto:cs@sahabatexport.com'>Email</a>
              <a href='https://wa.me/601129373730'>WhatsApp</a>
            </div>
          </nav>
        </div>
        <div class='footer-bottom'>
          <span
            >&copy; {year} Sahabat Export &middot; Bersama menuju pasar dunia</span
          >
          <span>Thank you for your interest in partnering with us.</span>
        </div>
      </div>
    </footer>
  </body>
</html>
