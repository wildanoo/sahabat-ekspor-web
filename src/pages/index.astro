---
import Layout from '../layouts/Layout.astro';

const markets = [
  { code: 'MY', flag: '\u{1F1F2}\u{1F1FE}', name: 'Malaysia', status: 'active' as const },
  { code: 'SG', flag: '\u{1F1F8}\u{1F1EC}', name: 'Singapore', status: 'active' as const },
  { code: 'BN', flag: '\u{1F1E7}\u{1F1F3}', name: 'Brunei', status: 'active' as const },
  { code: 'AU', flag: '\u{1F1E6}\u{1F1FA}', name: 'Australia', status: 'planned' as const },
  { code: 'US', flag: '\u{1F1FA}\u{1F1F8}', name: 'United States', status: 'planned' as const },
  { code: 'EU', flag: '\u{1F1EA}\u{1F1FA}', name: 'Europe', status: 'planned' as const },
];

const categories = [
  { code: 'FSH', name: 'Muslim Fashion', note: 'Hijab, pashmina, gamis' },
  { code: 'BTY', name: 'Beauty & Personal Care', note: 'Skincare & daily care' },
  { code: 'BBY', name: 'Baby & Kids Products', note: 'Everyday essentials' },
  { code: 'EDU', name: 'Educational Toys', note: 'Learning & play' },
  { code: 'HOM', name: 'Home & Living', note: 'Household goods' },
  { code: 'CGS', name: 'Consumer Goods', note: 'Fast-moving items' },
];

const channels = [
  'Direct-to-Consumer (DTC)',
  'Facebook Advertising',
  'WhatsApp Sales',
  'Marketplace Sales',
  'Cross-Border Fulfillment',
  'Cash on Delivery (where available)',
  'Local Payment Collection',
];

const testimonials = [
  { quote: 'They handle the marketing and delivery into Malaysia for us. We just ship to their hub and our hijab line sells out across the causeway.', who: 'Rina Hapsari', role: 'Founder \u00B7 Modest fashion label, Bandung' },
  { quote: 'Reaching Singapore customers used to feel impossible for a small skincare brand. Now our products land on doorsteps there every week.', who: 'Dewi Anggraini', role: 'Owner \u00B7 Beauty & skincare, Yogyakarta' },
  { quote: 'Clear reporting, fast payouts, and they actually understand cross-border. Our educational toys finally have a market beyond Indonesia.', who: 'Bambang Sutrisno', role: 'Director \u00B7 Kids & learning products, Surabaya' },
];

const faqs = [
  { q: 'Who is Sahabat Export for?', a: "Two groups: Indonesian sellers who want their products reaching customers abroad, and fulfillment, logistics, and payment partners who want to support cross-border trade into Southeast Asia. The website's primary focus is partnering with the latter to expand our network." },
  { q: 'Which markets do you currently serve?', a: 'We are actively serving Malaysia, Singapore, and Brunei today. Australia, the United States, and Europe are on our planned roadmap as the fulfillment network scales.' },
  { q: 'How do products actually reach customers abroad?', a: 'We market directly to consumers through Facebook Ads, WhatsApp, and marketplaces, then fulfill orders through our cross-border network \u2014 warehousing, freight, and local last-mile delivery, with local payment or cash-on-delivery where available.' },
  { q: 'What kind of partners are you looking for?', a: 'Warehousing and storage, fulfillment (pick & pack), freight and logistics, last-mile delivery, payment and COD collection, and marketplace or e-commerce service providers across Southeast Asia.' },
  { q: 'How do we start a conversation?', a: "Fill in the partnership inquiry form below, or reach us directly on WhatsApp or email. Tell us about your service, coverage, and capacity, and we'll follow up." },
];
---

<Layout
  title="Sahabat Export — Indonesian products to Malaysia & Singapore"
  description="Sahabat Export sells Indonesian products to customers in Malaysia and Singapore through digital marketing, marketplaces, and cross-border fulfillment. Bersama menuju pasar dunia."
>
  <!-- HEADER -->
  <header class="topbar" id="topbar">
    <div class="topbar-inner">
      <a href="#top" class="brand" aria-label="Sahabat Export — back to top">
        <img src="/assets/logo.png" alt="Sahabat Export — Bersama Menuju Pasar Dunia" class="brand-logo" />
      </a>
      <nav class="nav" aria-label="Page sections">
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#markets">Markets</a>
          <a href="#products">Products</a>
          <a href="#operate">How we work</a>
          <a href="#faq">FAQ</a>
        </div>
        <a href="#contact" class="btn btn-gold">Partner with us <span class="arrow">&rarr;</span></a>
      </nav>
    </div>
  </header>

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow on-dark">Cross-border e-commerce &middot; Indonesia &rarr; Southeast Asia</p>
            <h1>Indonesian products,<br />delivered to <span class="gold">Malaysia</span> &amp; <span class="gold">Singapore</span></h1>
            <p class="lede">
              Sahabat Export sells Indonesian products directly to customers across Southeast Asia
              through digital marketing, online marketplaces, and a growing cross-border
              fulfillment network.
            </p>
            <div class="hero-cta">
              <a href="#contact" class="btn btn-gold">Partner with us <span class="arrow">&rarr;</span></a>
              <a href="#operate" class="btn btn-ghost-light">See how we work</a>
            </div>
          </div>

          <!-- globe emblem -->
          <div class="hero-art" aria-hidden="true">
            <div class="globe-wrap">
              <svg class="globe-layer" viewBox="0 0 460 460" aria-hidden="true">
                <defs>
                  <radialGradient id="gGlobe" cx="38%" cy="30%" r="78%">
                    <stop offset="0%" stop-color="#14538f" />
                    <stop offset="55%" stop-color="#0b2d52" />
                    <stop offset="100%" stop-color="#061d39" />
                  </radialGradient>
                  <radialGradient id="gGlow" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="rgba(217,165,49,0.30)" />
                    <stop offset="100%" stop-color="rgba(217,165,49,0)" />
                  </radialGradient>
                  <linearGradient id="gGold" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#a9761a" />
                    <stop offset="50%" stop-color="#d9a531" />
                    <stop offset="100%" stop-color="#f1cb63" />
                  </linearGradient>
                </defs>
                <circle cx="230" cy="230" r="205" fill="url(#gGlow)" />
                <g class="orbit-spin">
                  <circle cx="230" cy="230" r="197" fill="none" stroke="url(#gGold)" stroke-width="1" stroke-dasharray="2 13" opacity="0.55" />
                  <circle cx="230" cy="33" r="3" fill="#f1cb63" />
                </g>
                <circle cx="230" cy="230" r="150" fill="url(#gGlobe)" stroke="rgba(241,203,99,0.55)" stroke-width="1.5" />
              </svg>

              <img class="globe-layer globe-map" src="/assets/globe-dots-zoom2.svg" alt="" aria-hidden="true" />

              <svg class="globe-layer" viewBox="0 0 460 460" aria-hidden="true">
                <defs>
                  <linearGradient id="gGold2" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#a9761a" />
                    <stop offset="50%" stop-color="#d9a531" />
                    <stop offset="100%" stop-color="#f1cb63" />
                  </linearGradient>
                  <clipPath id="clipGlobe2"><circle cx="230" cy="230" r="150" /></clipPath>
                </defs>
                <g clip-path="url(#clipGlobe2)" stroke="rgba(159,180,194,0.15)" fill="none" stroke-width="1">
                  <ellipse cx="230" cy="230" rx="150" ry="60" />
                  <ellipse cx="230" cy="230" rx="60" ry="150" />
                  <line x1="80" y1="230" x2="380" y2="230" />
                </g>
                <circle class="se-halo" cx="230" cy="188" r="60" fill="none" stroke="#f1cb63" stroke-width="1.2" stroke-dasharray="2 7" opacity="0.5" />
                <g fill="none" stroke="url(#gGold2)" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 6">
                  <path class="trade-arc" d="M 230 230 Q 209 203 199.4 174.2" />
                  <path class="trade-arc" d="M 230 230 Q 218 208 211.9 184.7" />
                  <path class="trade-arc" d="M 230 230 Q 263 203 278.7 164" />
                </g>
                <g class="nodes">
                  <circle cx="199.4" cy="174.2" r="4" fill="url(#gGold2)" stroke="#061d39" stroke-width="1" />
                  <circle cx="211.9" cy="184.7" r="4" fill="url(#gGold2)" stroke="#061d39" stroke-width="1" />
                  <circle cx="278.7" cy="164" r="4" fill="url(#gGold2)" stroke="#061d39" stroke-width="1" />
                  <circle cx="230" cy="230" r="5" fill="url(#gGold2)" stroke="#061d39" stroke-width="1" />
                  <circle class="node-pulse" cx="230" cy="230" r="5.5" fill="none" stroke="#f1cb63" stroke-width="2" />
                </g>
                <g class="globe-label">
                  <text x="191" y="170" text-anchor="end">KUL</text>
                  <text x="204" y="192" text-anchor="end">SIN</text>
                  <text x="288" y="161" text-anchor="start">BWN</text>
                  <text x="230" y="250" text-anchor="middle">JKT</text>
                </g>
              </svg>
            </div>
          </div>
        </div>

        <!-- route motif -->
        <svg class="route" viewBox="0 0 620 78" role="img" aria-label="Trade route from Jakarta to Kuala Lumpur, Singapore, and Brunei Darussalam">
          <path class="route-flow" d="M 22 60 C 180 -8, 430 -8, 598 52" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
          <circle cx="22" cy="60" r="5.5" fill="currentColor" />
          <circle cx="202" cy="15" r="5.5" fill="currentColor" />
          <circle cx="405" cy="12" r="5.5" fill="currentColor" />
          <circle cx="598" cy="52" r="5.5" fill="currentColor" />
          <text x="22" y="28" class="route-label route-city" text-anchor="start">JAKARTA</text>
          <text x="202" y="44" class="route-label route-city" text-anchor="middle">KUALA LUMPUR</text>
          <text x="405" y="41" class="route-label route-city" text-anchor="middle">SINGAPORE</text>
          <text x="598" y="30" class="route-label route-city" text-anchor="end">BRUNEI</text>
        </svg>

        <!-- stats -->
        <div class="hero-stats">
          <div class="stat"><span class="num">3</span><span class="lab">Markets serving now</span></div>
          <div class="stat"><span class="num">6</span><span class="lab">Product categories</span></div>
          <div class="stat"><span class="num">7</span><span class="lab">Sales channels</span></div>
          <div class="stat"><span class="num">ID&rarr;SEA</span><span class="lab">Fulfillment lane</span></div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section" id="about">
      <div class="wrap">
        <div class="cols-2">
          <div class="section-head" style="margin-bottom:0">
            <span class="eyebrow">About us</span>
            <h2>We specialize in cross-border online sales</h2>
          </div>
          <div>
            <p class="lead-p body-p">
              We market products directly to consumers in Malaysia and Singapore using
              Facebook Ads, WhatsApp sales, marketplace channels, and other digital platforms.
            </p>
            <p class="body-p muted">
              To support our growth, we continuously build partnerships with reliable
              fulfillment and warehousing providers across Southeast Asia &mdash; making it
              simple for Indonesian sellers to reach international customers.
            </p>
          </div>
        </div>

        <div class="feature-row">
          <div class="feature">
            <span class="fnum">01</span>
            <h3>Direct-to-consumer reach</h3>
            <p>We acquire and serve customers ourselves &mdash; not through a reseller chain &mdash; so products move fast.</p>
          </div>
          <div class="feature">
            <span class="fnum">02</span>
            <h3>Digital-first marketing</h3>
            <p>Paid social, WhatsApp, and marketplaces drive demand across each destination market.</p>
          </div>
          <div class="feature">
            <span class="fnum">03</span>
            <h3>Reliable fulfillment</h3>
            <p>A scalable cross-border network handles warehousing, shipping, and local delivery.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- MARKETS -->
    <section class="section dark" id="markets">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow on-dark">Markets we serve</span>
          <h2>Destinations &amp; status</h2>
        </div>
        <div class="board" role="table" aria-label="Destination markets and status">
          <div class="board-row board-head" role="row">
            <span role="columnheader">Code</span>
            <span role="columnheader">Destination</span>
            <span role="columnheader">Status</span>
          </div>
          {markets.map((m) => (
            <div class="board-row" role="row">
              <span class="board-code" role="cell">{m.code}</span>
              <span class="board-name" role="cell">
                <span class="board-flag" aria-hidden="true">{m.flag}</span>
                {m.name}
              </span>
              <span class={`board-status ${m.status}`} role="cell">
                {m.status === 'active' ? 'Serving now' : 'Planned'}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="section" id="products">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Product categories</span>
          <h2>What we sell</h2>
        </div>
        <div class="cat-grid">
          {categories.map((c) => (
            <div class="cat">
              <span class="cat-code">{c.code}</span>
              <div class="cat-name">{c.name}</div>
              <div class="cat-note">{c.note}</div>
            </div>
          ))}
        </div>
        <p class="footnote">Product categories may vary based on market demand and seasonal trends.</p>
      </div>
    </section>

    <!-- OPERATE / CHANNELS -->
    <section class="section paper-2" id="operate">
      <div class="wrap">
        <div class="cols-2">
          <div class="section-head" style="margin-bottom:0">
            <span class="eyebrow">Business model</span>
            <h2>How we work</h2>
            <p class="body-p muted" style="margin-top:1.2rem; max-width:34ch">
              A direct-to-consumer engine, wired to local payment and delivery in every market.
            </p>
          </div>
          <ul class="chan-list">
            {channels.map((c, i) => (
              <li class="chan">
                <span class="chan-i">{String(i + 1).padStart(2, '0')}</span>
                <span class="chan-name">{c}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="section dark" id="sellers">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow on-dark">From the sellers we carry</span>
          <h2>Trusted by Indonesian brands</h2>
        </div>
        <div class="quote-grid">
          {testimonials.map((t) => (
            <figure class="quote">
              <div class="mark" aria-hidden="true">&ldquo;</div>
              <p>{t.quote}</p>
              <footer>
                <span class="who">{t.who}</span>
                <span class="role">{t.role}</span>
              </footer>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Frequently asked</span>
          <h2>Questions, answered</h2>
        </div>
        <div class="faq">
          {faqs.map((f, i) => (
            <details open={i === 0}>
              <summary>
                <span class="q">{f.q}</span>
                <span class="tog" aria-hidden="true"></span>
              </summary>
              <div class="answer"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT + FORM -->
    <section class="section paper-2" id="contact">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Partnership inquiry</span>
          <h2>Build the network with us</h2>
        </div>
        <div class="contact-grid">
          <div>
            <p class="contact-copy">
              We welcome discussions with warehouse, fulfillment, logistics, last-mile, and
              payment providers interested in supporting our expansion across Southeast Asia.
              Tell us about your service and we'll be in touch.
            </p>
          </div>

          <address class="label-card">
            <div class="label-route" aria-hidden="true">
              <span>From &middot; Indonesia</span>
              <span class="label-arrow">&rarr;</span>
              <span>To &middot; Southeast Asia</span>
            </div>
            <dl>
              <div class="label-row"><dt>Email</dt><dd><a href="mailto:hello@sahabatexport.com">hello@sahabatexport.com</a></dd></div>
              <div class="label-row"><dt>WhatsApp</dt><dd><a href="https://wa.me/601129373730">+60 11-2937-3730</a></dd></div>
              <div class="label-row"><dt>Website</dt><dd><a href="https://www.sahabatexport.com">www.sahabatexport.com</a></dd></div>
            </dl>
          </address>
        </div>
      </div>
    </section>

    <!-- CTA BAND -->
    <section class="cta-band">
      <div class="cta-band-inner">
        <div>
          <h2>Bersama menuju pasar dunia</h2>
          <p>Together toward the world's markets. Let's grow the cross-border lane for Indonesian products.</p>
        </div>
        <a href="#contact" class="btn btn-gold">Start a conversation <span class="arrow">&rarr;</span></a>
      </div>
    </section>
  </main>

  <script>
    // Header scroll state
    (function headerScroll() {
      const bar = document.getElementById('topbar');
      if (!bar) return;
      const onScroll = () => bar.classList.toggle('scrolled', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();

    // Reveal on scroll
    (function reveal() {
      const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!motionOk || !('IntersectionObserver' in window)) return;
      const targets = document.querySelectorAll('.section-head, .feature, .cat, .quote, .board, .chan-list, .label-card, .form, .cta-band-inner');
      targets.forEach((t) => t.classList.add('reveal'));
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e, idx) => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).style.transitionDelay = Math.min(idx * 40, 160) + 'ms';
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      targets.forEach((t) => io.observe(t));
    })();

  </script>
</Layout>

<style is:global>
  /* ==================================================================
     SAHABAT EXPORT — elevated manifest design system
     Deep harbour navy · metallic gold · warm paper
     Display: Archivo (condensed) · Body: Source Sans 3 · Mono: IBM Plex Mono
  ================================================================== */
  :root {
    /* navy family */
    --navy:       #0b2d52;
    --navy-2:     #0a2647;
    --navy-deep:  #061d39;
    --navy-ink:   #04101f;
    /* paper family */
    --paper:      #f4f2ea;
    --paper-2:    #faf8f1;
    --paper-card: #fffdf6;
    /* ink + grey */
    --ink:        #16212c;
    --grey:       #5d6b73;
    --grey-light: #8aa0ae;
    /* gold family (metallic) */
    --gold:       #d9a531;
    --gold-hi:    #f1cb63;
    --gold-deep:  #a9761a;
    --gold-text:  #9c660f;
    /* lines */
    --line:       #ddd9cd;
    --line-soft:  #e7e3d8;
    --line-dark:  rgba(244, 242, 234, 0.16);
    /* status */
    --green:      #2f8a5b;
    --amber:      #b07c1f;
    /* gradients */
    --grad-gold:  linear-gradient(98deg, var(--gold-deep) 0%, var(--gold) 42%, var(--gold-hi) 100%);
    --grad-navy:  linear-gradient(165deg, var(--navy) 0%, var(--navy-deep) 62%, var(--navy-ink) 100%);

    --display: 'Archivo', system-ui, sans-serif;
    --body:    'Source Sans 3', system-ui, sans-serif;
    --mono:    'IBM Plex Mono', ui-monospace, monospace;

    --max: 1140px;
    --pad: clamp(1.25rem, 4vw, 2.5rem);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after { animation: none !important; transition: none !important; }
  }

  body {
    font-family: var(--body);
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--ink);
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  img { max-width: 100%; display: block; }
  ::selection { background: var(--gold); color: var(--navy-ink); }

  a { color: var(--gold-text); text-underline-offset: 3px; }
  a:focus-visible, button:focus-visible, summary:focus-visible,
  input:focus-visible, select:focus-visible, textarea:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
  }

  h1, h2, h3 {
    font-family: var(--display);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    font-variation-settings: 'wdth' 78;
  }

  /* metallic gold word */
  .gold {
    background: var(--grad-gold);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: var(--gold);
  }

  .wrap { max-width: var(--max); margin-inline: auto; padding-inline: var(--pad); }

  /* mono eyebrow with leading rule */
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-text);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .eyebrow::before {
    content: '';
    width: 1.8rem;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }
  .eyebrow.on-dark { color: var(--gold-hi); }

  /* ============================ HEADER ============================ */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color .3s ease, box-shadow .3s ease, background .3s ease;
  }
  .topbar.scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 6px 24px -18px rgba(6, 29, 57, 0.5);
  }
  .topbar-inner {
    max-width: var(--max);
    margin-inline: auto;
    padding: 0.85rem var(--pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand { display: inline-flex; align-items: center; }
  .brand-logo { height: 46px; width: auto; }
  @media (max-width: 760px) { .brand-logo { height: 36px; } }

  .nav { display: flex; gap: 1.6rem; align-items: center; }
  .nav a {
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--ink);
    position: relative;
    padding: 0.2rem 0;
    white-space: nowrap;
  }
  .nav a:not(.btn)::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 0; height: 1.5px;
    background: var(--grad-gold);
    transition: width .25s ease;
  }
  .nav a:not(.btn):hover::after { width: 100%; }
